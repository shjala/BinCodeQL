# Profile: Claude (Anthropic native).
# Copy to magma_eval/.env.eval.claude and fill ANTHROPIC_API_KEY.
# Loaded by eval_one.py --profile claude AFTER the project .env, so
# values here override the global model config.

# Native Anthropic — no MODEL_BASE_URL / MODEL_API_KEY_ENV / MODEL_EXTRA_BODY.
MODEL_NAME="anthropic/claude-sonnet-4-5"
MODEL_BASE_URL=
MODEL_API_KEY_ENV=
MODEL_EXTRA_BODY=
MODEL_THINKING="off"
# Anthropic rejects temperature+top_p together; blank both so any global
# .env values for an OSS-model session don't leak through.
MODEL_TOP_P=
MODEL_TEMPERATURE=

# Eval-time fail-fast: cap retries + per-call timeout so a single
# rate-limited candidate can't burn 45+ minutes of wall time.
MODEL_NUM_RETRIES=2
MODEL_TIMEOUT=120

ANTHROPIC_API_KEY="sk-ant-..."
