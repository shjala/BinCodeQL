# Profile: DeepSeek (OSS arm via official API).
# Copy to magma_eval/.env.eval.deepseek and fill DEEPSEEK_API_KEY.
# Loaded by eval_one.py --profile deepseek AFTER the project .env, so
# values here override the global model config.

# OpenAI-compatible endpoint — agent_factory routes via litellm.
# `deepseek-v4-flash` is the current cheap model ($0.14/$0.28 per M tok,
# 1M context). `deepseek-chat` is deprecated 2026-07-24.
MODEL_NAME="openai/deepseek-v4-flash"
MODEL_BASE_URL="https://api.deepseek.com"
MODEL_API_KEY_ENV="DEEPSEEK_API_KEY"

# v4-flash defaults to thinking-on. Disable it via the v4-native param
# `{"thinking":{"type":"disabled"}}` — faster (0.8s vs 2.6s in probes)
# and cheaper, since our triage agent does its own multi-turn reasoning.
MODEL_EXTRA_BODY='{"thinking":{"type":"disabled"}}'
# Leave MODEL_THINKING blank so agent_factory's auto-fill (which uses
# the older `chat_template_kwargs.thinking` field) is skipped.
MODEL_THINKING=

# DeepSeek's recommended temperature for code/math/reasoning tasks.
MODEL_TEMPERATURE="0.0"
MODEL_TOP_P=

# Eval-time fail-fast: cap retries + per-call timeout.
MODEL_NUM_RETRIES=2
MODEL_TIMEOUT=120

DEEPSEEK_API_KEY="sk-..."
