# Profile: DeepSeek v4-pro (premium reasoning model).
# 3x the cost of v4-flash (~$0.435/$0.87 per M tok). Use for ablation
# on candidates where v4-flash returned ambiguous/uncertain verdicts.
# Copy to magma_eval/.env.eval.deepseek-pro and reuse the same key.

MODEL_NAME="openai/deepseek-v4-pro"
MODEL_BASE_URL="https://api.deepseek.com"
MODEL_API_KEY_ENV="DEEPSEEK_API_KEY"

# v4-pro is the explicit reasoning model — keep thinking ENABLED.
MODEL_EXTRA_BODY='{"thinking":{"type":"enabled"}}'
MODEL_THINKING=

MODEL_TEMPERATURE="0.0"
MODEL_TOP_P=

MODEL_NUM_RETRIES=2
# Pro+thinking takes longer per call; widen the per-call timeout.
MODEL_TIMEOUT=240

DEEPSEEK_API_KEY="sk-..."
