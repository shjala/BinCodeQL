# =============================================================================
# BinCodeQL Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored — your secrets and local paths stay private.
# =============================================================================

# =============================================================================
# Model Configuration
# =============================================================================
# LiteLLM model ID. Auto-picks API key based on prefix.
# Examples: anthropic/claude-sonnet-4-6, openai/gpt-5, openai/gpt-5.2
#
# Recommended: anthropic/claude-sonnet-4-6 — best cost/quality balance and
# the highest per-minute input-token rate limit of the Claude family.
#
# Opus (claude-opus-4-6 / claude-opus-4-7) has stricter per-minute caps
# (~450K input tokens/min). For long agent sessions the Opus cap is the
# first thing to hit — prefer Sonnet unless you need Opus's extra depth
# on a single-shot question. Prompt caching (enabled automatically by
# agent.py for anthropic/* models) keeps both well under their caps.
MODEL_NAME="anthropic/claude-sonnet-4-6"

# Per-request timeout in seconds (default 180). Raise for very long tool
# chains; lower for tighter failure loops.
#MODEL_TIMEOUT=180

# Retries on transient errors (default 4). LiteLLM applies exponential
# backoff automatically between attempts, which smooths over rate-limit
# spikes without surfacing them to the user.
#MODEL_NUM_RETRIES=4

# Anthropic cache TTL. Options: "1h" (default — 2× first-write cost, but
# 0.08× per read for 60 min; best for binary-analysis sessions that pause
# to think) or "5m" (1.25× first-write, 0.1× per read for 5 min; cheapest
# for bursty sessions). Requires anthropic/* model.
#MODEL_CACHE_TTL=1h

# Anthropic extended thinking budget in tokens. When > 0, the model runs
# an internal reasoning pass before producing its final answer — this is
# what makes Sonnet 4.6 match Opus 4.6 on deep reasoning tasks (value-
# range arguments, hypothesis generation, Datalog composition). Default
# 10000 is a balanced budget; raise to 16000–24000 for very subtle
# analyses, set to 0 to disable (e.g. for non-reasoning quick queries).
# Only takes effect for anthropic/* models.
#MODEL_THINKING_BUDGET=10000

# Max output tokens per response. Defaults to max(4096, thinking_budget+
# 4096). Override only if you want shorter replies or room for very long
# Datalog programs in the response body.
#MODEL_MAX_TOKENS=14096

# =============================================================================
# Souffle Datalog execution
# =============================================================================
# Number of threads for Souffle's Datalog evaluator. "auto" = all cores.
# Set to "1" to disable parallelism (rare — for reproducibility debugging).
# Helps most on transitive-closure-heavy rules (bn_flow.dl, interproc.dl)
# that bottleneck on large function fact-sets.
#SOUFFLE_JOBS=auto

# When 1, compile Datalog rules to C++ (-c) and execute. Adds 30s-2min
# compile overhead per rule file on first run, but evaluation runs
# 10-100x faster once compiled — worthwhile for repeated runs over large
# fact sets. Default off because the compile overhead hurts one-shot
# exploratory queries.
#SOUFFLE_COMPILE=0

# =============================================================================
# API Keys — set the key(s) for your chosen provider(s)
# =============================================================================
# API_KEY overrides provider-specific keys (use if you want one key for all):
#API_KEY=""

# Provider-specific keys (auto-selected based on MODEL_NAME prefix):
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
#GOOGLE_API_KEY=""
#OPENROUTER_API_KEY=""
#NVIDIA_API_KEY=""

# =============================================================================
# OpenAI-compatible / self-hosted inference (NVIDIA build, vLLM, etc.)
# =============================================================================
# When set, MODEL_BASE_URL is forwarded to LiteLLM as `api_base` so the
# OpenAI client routes requests to your endpoint instead of the default.
# Use together with an `openai/<model_id>` MODEL_NAME — LiteLLM picks the
# OpenAI client based on the prefix and the api_base redirects it.
#
# Examples:
#   NVIDIA build endpoint:
#     MODEL_BASE_URL="https://integrate.api.nvidia.com/v1"
#     MODEL_NAME="openai/minimaxai/minimax-m2.7"
#     MODEL_API_KEY_ENV="NVIDIA_API_KEY"
#
#   Local vLLM / llama.cpp server:
#     MODEL_BASE_URL="http://localhost:8000/v1"
#     MODEL_NAME="openai/<served-model-id>"
#     MODEL_API_KEY_ENV="LOCAL_API_KEY"  # any non-empty string usually
#
# Anthropic-only features (prompt caching, extended thinking) are skipped
# when MODEL_NAME is not anthropic/*, so open-source models work without
# tweaking anything else.
#MODEL_BASE_URL=""

# Name of the env var holding the API key for the active model. Lets you
# keep multiple provider keys side-by-side and switch by changing one
# line, instead of overwriting OPENAI_API_KEY each time.
#MODEL_API_KEY_ENV=""

# Sampling controls for non-Anthropic models. Some open-source providers
# require these (e.g. NVIDIA build's deepseek-v4-pro wants top_p=0.95
# and the chat-template thinking flag below). Anthropic models ignore
# these and use thinking-budget + the auto-set temperature instead.
#MODEL_TEMPERATURE=""
#MODEL_TOP_P=""

# JSON object forwarded as `extra_body` on every request. Use for
# provider-specific knobs not modeled by the OpenAI schema. Example —
# disable deepseek-v4-pro's internal reasoning pass for faster replies:
#   MODEL_EXTRA_BODY='{"chat_template_kwargs":{"thinking":false}}'
#MODEL_EXTRA_BODY=""

# Slow open-source models (deepseek-v4-pro on NVIDIA build measured
# 90-300s per call during quiet hours) need a longer per-request
# timeout — bump MODEL_TIMEOUT to 300+ if you see Timeout errors.

# =============================================================================
# Binary Ninja MCP Bridge
# =============================================================================
# Python interpreter inside the MCP bridge venv (must have mcp package)
MCP_PYTHON_PATH="/path/to/binary_ninja_mcp/.venv/bin/python3"

# Path to the MCP bridge script
MCP_BRIDGE_PATH="/path/to/binary_ninja_mcp/bridge/binja_mcp_bridge.py"

# =============================================================================
# Binary Ninja Headless (for batch fact extraction)
# =============================================================================
# Option A: Full path to a Python interpreter with binaryninja installed
#BN_PYTHON="/path/to/python3"

# Option B: Path to binaryninja Python package directory
#   (added to PYTHONPATH when running headless extraction)
#BN_PYTHON_PATH="/path/to/binaryninja/python"

# =============================================================================
# Pre-analyzed Binary Ninja Database (optional, speeds up extraction)
# =============================================================================
# If set, tool_extract_facts_batch uses this as the default binary_path.
# .bndb files load in milliseconds (vs seconds/minutes for raw binaries)
# and include user-refined analysis (renamed functions, custom types).
#BNDB_PATH="/path/to/target.bndb"

# =============================================================================
# ADK / Vertex AI (optional)
# =============================================================================
GOOGLE_GENAI_USE_VERTEXAI=FALSE
